# mapbox_maps_flutter requires iOS 14.0+
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Enforce iOS 14.0 minimum across all pods to match our platform requirement.
    # Fixes deployment target warnings from: flutter_local_notifications (11.0),
    # flutter_native_splash (9.0), fluttertoast (9.0), geolocator_apple (11.0),
    # Turf (11.0), geocoding_ios (9.0).
    target.build_configurations.each do |config|
      current = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f
      if current < 14.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      end
    end
  end

  # Suppress deprecation/compiler warnings in third-party pods whose source we
  # cannot modify. These are upstream issues tracked by each package maintainer.
  pods_to_silence = %w[
    camera_avfoundation
    flutter_local_notifications
    fluttertoast
    geocoding_ios
    geolocator_apple
    MapboxMaps
    mapbox_maps_flutter
    permission_handler_apple
  ]
  installer.pods_project.targets.each do |target|
    next unless pods_to_silence.include?(target.name)
    target.build_configurations.each do |config|
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
    end
  end

  # Fix geocoding_ios PrivacyInfo.xcprivacy being misidentified as text.xml.
  # Xcode cannot process it under that type, so we correct the file type.
  installer.pods_project.files.each do |file|
    if file.path =~ /PrivacyInfo\.xcprivacy$/
      file.last_known_file_type = 'text.xcprivacy'
    end
  end

  project = Xcodeproj::Project.open("#{installer.sandbox.root}/../Runner.xcodeproj")
  runner_target = project.targets.find { |t| t.name == 'Runner' }

  # ── Fix "Upload Symbols Failed" for Mapbox binary frameworks ─────────────
  # Mapbox ships pre-compiled frameworks without dSYMs. This script generates
  # them at archive time so App Store Connect can symbolicate Mapbox frames.
  # Always regenerate (no [ ! -d ] guard) so a stale dSYM with a wrong UUID
  # never silently persists across builds.
  phase_name = 'Generate Mapbox dSYMs'
  phase = runner_target.shell_script_build_phases.find { |p| p.name == phase_name }
  unless phase
    phase = runner_target.new_shell_script_build_phase(phase_name)
  end
  phase.shell_script = <<~'SCRIPT'
    for framework in MapboxCommon MapboxCoreMaps objective_c; do
      FW_PATH="${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}/${framework}.framework/${framework}"
      DSYM_PATH="${DWARF_DSYM_FOLDER_PATH}/${framework}.framework.dSYM"
      if [ -f "$FW_PATH" ]; then
        echo "Generating dSYM for ${framework}..."
        xcrun dsymutil "$FW_PATH" -o "$DSYM_PATH" 2>/dev/null || true
      fi
    done
  SCRIPT
  phase.always_out_of_date = '1'

  # ── Strip simulator-platform slices from embedded frameworks ─────────────
  # On Apple Silicon Macs, the Dart objective_c package produces a fat
  # framework where the arm64 slice carries LC_BUILD_VERSION platform=IOSSIMULATOR.
  # App Store Connect rejects any binary with simulator-tagged slices.
  # This script uses `vtool` to identify and `lipo` to remove such slices
  # after Xcode embeds the frameworks but before code-signing.
  # Fixes:
  #   "executable references an unsupported platform in the arm64 slice"
  #   "bundle does not support the minimum OS Version specified in the Info.plist"
  strip_phase_name = 'Strip Simulator Slices'
  strip_phase = runner_target.shell_script_build_phases.find { |p| p.name == strip_phase_name }
  unless strip_phase
    strip_phase = runner_target.new_shell_script_build_phase(strip_phase_name)
  end
  strip_phase.shell_script = <<~'SCRIPT'
    APP_PATH="${TARGET_BUILD_DIR}/${WRAPPER_NAME}"
    find "$APP_PATH" -name '*.framework' -type d | while IFS= read -r FRAMEWORK; do
      BINARY_NAME=$(defaults read "$FRAMEWORK/Info.plist" CFBundleExecutable 2>/dev/null) || continue
      BINARY="$FRAMEWORK/$BINARY_NAME"
      [ -f "$BINARY" ] || continue

      ALL_ARCHS=$(lipo -archs "$BINARY" 2>/dev/null) || continue
      for ARCH in $ALL_ARCHS; do
        PLATFORM=$(vtool -show-build "$BINARY" -arch "$ARCH" 2>/dev/null | awk '/platform:/{print $2; exit}')
        if [ "$PLATFORM" = "IOSSIMULATOR" ] || [ "$PLATFORM" = "MACCATALYST" ]; then
          echo "$(basename $FRAMEWORK): removing $ARCH ($PLATFORM)"
          lipo -remove "$ARCH" -output "$BINARY" "$BINARY" 2>/dev/null || true
        fi
      done
    done
  SCRIPT
  # Must run after "Embed Frameworks" and before "Sign" — set deployment postprocessing flag
  strip_phase.run_only_for_deployment_postprocessing = '1'
  strip_phase.always_out_of_date = '1'

  # ── Prevent actool from re-encoding the app icon as ARGB ─────────────────
  # Xcode's asset catalog compiler can convert a clean RGB PNG to ARGB when
  # optimising for performance. App Store Connect rejects icons with alpha.
  # "space" optimisation keeps the original pixel format.
  runner_target.build_configurations.each do |config|
    next unless config.name == 'Release'
    config.build_settings['ASSETCATALOG_COMPILER_OPTIMIZATION'] = 'space'
    # Prevent pngcrush/actool from re-encoding the app icon with an alpha channel.
    # actool can convert a clean RGB PNG to ARGB regardless of the source format.
    config.build_settings['COMPRESS_PNG_FILES'] = 'NO'
  end

  project.save
end
